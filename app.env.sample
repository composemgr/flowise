# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=localhost

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# App secret key (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database type: sqlite (default) or postgres
DB_TYPE=sqlite
